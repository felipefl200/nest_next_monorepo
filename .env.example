# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce_admin?schema=public"

# JWT (RS256)
# Use PEM-encoded keys (single line escaped or multiline loaded by your env tool)
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nYOUR_PRIVATE_KEY\\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\nYOUR_PUBLIC_KEY\\n-----END PUBLIC KEY-----"
JWT_ISSUER="ecommerce-admin-api"
JWT_AUDIENCE="ecommerce-admin-web"
JWT_ACCESS_TOKEN_EXPIRES_IN="10m"
JWT_REFRESH_TOKEN_EXPIRES_IN="7d"
AUTH_CHECK_IP_ON_REFRESH="false"

# App
PORT="3333"
API_URL="http://localhost:3333"
APP_CORS_ORIGIN="http://localhost:3000"

# Seeds
ADMIN_SEED_PASSWORD="admin123"

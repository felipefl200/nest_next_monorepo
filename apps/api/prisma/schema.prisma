generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        String   @id @default(cuid())
  name      String   @unique
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String
  isActive        Boolean         @default(true)
  isEmailVerified Boolean         @default(false)
  tokenVersion    Int             @default(0)
  roleId          String
  role            Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  credential      UserCredential?
  sessions        Session[]
  ownedCustomers  Customer[]      @relation("UserOwnedCustomers")
  ownedProducts   Product[]       @relation("UserOwnedProducts")
  ownedOrders     Order[]         @relation("UserOwnedOrders")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([roleId])
}

model UserCredential {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash      String
  passwordChangedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Session {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  userAgent        String?
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RateLimitEntry {
  key       String   @id
  count     Int
  expiresAt DateTime
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELED
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String
  taxId       String?  @unique
  ownerUserId String
  ownerUser   User     @relation("UserOwnedCustomers", fields: [ownerUserId], references: [id], onDelete: Restrict)
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerUserId])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String?
  category    String
  price       Decimal     @db.Decimal(10, 2)
  stock       Int
  isActive    Boolean     @default(true)
  ownerUserId String
  ownerUser   User        @relation("UserOwnedProducts", fields: [ownerUserId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([category])
  @@index([isActive])
  @@index([ownerUserId])
}

model Order {
  id          String      @id @default(cuid())
  number      String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  ownerUserId String
  ownerUser   User        @relation("UserOwnedOrders", fields: [ownerUserId], references: [id], onDelete: Restrict)
  status      OrderStatus @default(PENDING)
  total       Decimal     @db.Decimal(10, 2)
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([customerId])
  @@index([ownerUserId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int
  unitPrice Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
}

model Setting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
